# Runtime mode
# - openai: uses OpenAI embeddings + OpenAI chat model
# - local: uses Ollama embeddings + Ollama chat model (offline/local)
MODEL_PROVIDER=openai

# Required only for MODEL_PROVIDER=openai
OPENAI_API_KEY=

# Models
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# Storage
CHROMA_PERSIST_DIR=data/chroma
AUDIT_DB_PATH=data/audit.db

# Security: API keys (change these)
API_KEY_ADMIN=admin-key-change-me
API_KEY_REVIEWER=reviewer-key-change-me
API_KEY_ANALYST=analyst-key-change-me

# App
APP_ENV=dev

